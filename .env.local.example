# Copy this file to .env.local and fill in your Razorpay TEST MODE keys
# (Settings → API Keys in the Razorpay dashboard, with "Test Mode" toggled on).
#
# RAZORPAY_KEY_ID is safe to expose to the browser — the checkout script
# needs it. RAZORPAY_KEY_SECRET must NEVER be exposed; it's only read
# inside app/api/create-order and app/api/verify-payment.
#
# .env.local is already gitignored — never commit real keys.

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_key_secret_here
